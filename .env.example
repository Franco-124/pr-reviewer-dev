# GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Set exactly ONE of these two:
# - GITHUB_PRIVATE_KEY_PATH: path to the .pem file (local dev)
# - GITHUB_PRIVATE_KEY: full PEM contents as a single env var (deploys with
#   an ephemeral filesystem, e.g. Render — paste the .pem contents as-is,
#   newlines included)
GITHUB_PRIVATE_KEY_PATH=
GITHUB_PRIVATE_KEY=

# FastAPI
HOST=0.0.0.0
PORT=8000

# Webhook secret (HMAC validation)
GITHUB_WEBHOOK_SECRET=

# LLM
OPENAI_API_KEY=
LLM_MODEL_NAME=gpt-4.1-mini
